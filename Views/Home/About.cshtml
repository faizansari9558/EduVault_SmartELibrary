@{
    ViewData["Title"] = "About EduVault";
}

<style>
    .info-page-section { padding: 40px 20px 60px; max-width: 900px; margin: 0 auto; min-height: calc(100vh - 200px); }
    .info-card { background: var(--glass-bg, rgba(20, 20, 25, 0.7)); border: 1px solid var(--glass-border, rgba(255, 255, 255, 0.1)); border-radius: 20px; padding: 40px; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3), 0 0 20px rgba(138, 43, 226, 0.1); position: relative; overflow: hidden; }
    .info-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, #c084fc, transparent); opacity: 0.8; }
    .info-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 30px; text-align: center; letter-spacing: -0.5px; background: linear-gradient(90deg, #fff, #c9a0ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .info-content p { color: rgba(226, 232, 240, 0.9); line-height: 1.8; font-size: 1.05rem; margin-bottom: 20px; }
    .info-section-title { font-size: 1.5rem; font-weight: 700; color: #fff; margin: 35px 0 20px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; }
    .principle-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin: 30px 0; }
    .principle-card { background: rgba(0,0,0,0.2); padding: 25px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); }
    .principle-card h3 { color: #A855F7; font-size: 1.3rem; margin-bottom: 15px; }
    .feature-list { list-style: none; padding: 0; }
    .feature-list li { margin-bottom: 12px; padding-left: 30px; position: relative; color: rgba(226, 232, 240, 0.9); }
    .feature-list li::before { content: '✓'; position: absolute; left: 0; color: #4F9CF9; font-weight: bold; font-size: 1.1rem; }
    .dev-info { background: linear-gradient(135deg, rgba(88, 28, 135, 0.2), rgba(37, 99, 235, 0.1)); padding: 25px; border-radius: 16px; margin-top: 30px; border: 1px solid rgba(138, 43, 226, 0.2); }
    .tech-stack { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 15px; }
    .tech-badge { background: rgba(255,255,255,0.1); padding: 6px 12px; border-radius: 50px; font-size: 0.85rem; color: #e5eefb; }
    
    @@media (max-width: 768px) {
        .info-card { padding: 25px 20px; }
        .info-title { font-size: 2rem; }
    }
</style>

<div class="info-page-section">
    <div class="info-card">
        <h1 class="info-title">About EduVault</h1>
        
        <div class="info-content">
            <p>EduVault is a modern digital learning platform designed to help students access organized study materials, take quizzes, and track their academic progress in one centralized system.</p>
            
            <p>The platform provides a structured learning environment where teachers upload study materials and quizzes while students read chapters, complete quizzes, and monitor their learning performance.</p>

            <div class="principle-grid">
                <div class="principle-card">
                    <h3>Learn</h3>
                    <p class="mb-0">Students can access structured educational content organized by semester and subject.</p>
                </div>
                <div class="principle-card">
                    <h3>Store</h3>
                    <p class="mb-0">Study materials are organized and securely stored in a digital academic library.</p>
                </div>
                <div class="principle-card">
                    <h3>Succeed</h3>
                    <p class="mb-0">Students can track their progress and improve their academic performance using built-in analytics.</p>
                </div>
            </div>

            <h2 class="info-section-title">Key Features</h2>
            <ul class="feature-list">
                <li>Digital academic library</li>
                <li>Chapter-based structured learning</li>
                <li>Quiz-based evaluation system</li>
                <li>Student progress analytics</li>
                <li>Teacher content management</li>
                <li>Admin control dashboard</li>
            </ul>

            <div class="dev-info">
                <h3 style="font-size: 1.2rem; margin-bottom: 15px; color: #fff;">Developer Information</h3>
                <p style="margin-bottom: 5px;"><strong>Developed by:</strong> Ansari Faiz Alam Mahmood</p>
                <p style="margin-bottom: 15px;"><strong>Mission:</strong> To build a simple, organized, and modern digital learning platform where students can easily access knowledge and track their academic growth.</p>
                
                <h4 style="font-size: 1rem; color: #a1a1aa; margin-bottom: 10px;">Technology Stack</h4>
                <div class="tech-stack">
                    <span class="tech-badge">ASP.NET Core (.NET 10)</span>
                    <span class="tech-badge">MySQL Database</span>
                    <span class="tech-badge">Entity Framework Core</span>
                    <span class="tech-badge">HTML / CSS / JS</span>
                </div>
            </div>
        </div>
    </div>
</div>
