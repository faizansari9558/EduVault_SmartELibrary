@model SmartELibrary.ViewModels.VerifyForgotPasswordOtpViewModel
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card auth-card">
            <div class="card-body">
                <h4 class="mb-1">Verify OTP</h4>
                <p class="mb-3">Enter the 6-digit OTP sent to @Model.PhoneNumber</p>
                @if (TempData["DebugOtp"] != null)
                {
                    <div class="alert alert-info py-2 small mb-3">
                        Debug Mode: OTP is <b style="letter-spacing: 2px;">@TempData["DebugOtp"]</b>
                    </div>
                }
                <form asp-action="VerifyForgotPasswordOtp" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="PhoneNumber" />
                    <div class="mb-3">
                        <label asp-for="OtpCode" class="form-label"></label>
                        <input asp-for="OtpCode" class="form-control" maxlength="6" autocomplete="off" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Verify OTP</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
