@model SmartELibrary.ViewModels.UnifiedVerifiedRegistrationViewModel
@{
    ViewData["Title"] = "Register";
    var step = Model.Step <= 0 ? 1 : Model.Step;
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card auth-card">
            <div class="card-body">
                <h4 class="mb-3">Register</h4>
                <p class="text-muted small">Verify your enrollment or teacher record, confirm the email OTP, then create your password.</p>

                <div asp-validation-summary="All" class="text-danger mb-2"></div>

                @if (TempData["DebugOtp"] is not null)
                {
                    <div class="alert alert-info py-2">Demo OTP: <strong>@TempData["DebugOtp"]</strong></div>
                }

                @if (step == 1)
                {
                    <form asp-action="SendRegistrationOtp" method="post" class="mb-3">
                        @Html.AntiForgeryToken()

                        <div class="mb-2">
                            <label asp-for="UserId" class="form-label"></label>
                            <input asp-for="UserId" class="form-control" />
                        </div>

                        <div class="mb-2">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" type="email" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">Send OTP</button>
                    </form>
                }

                @if (step == 2)
                {
                    <div class="alert alert-success py-2">Verified identity: <strong>@Model.VerifiedName</strong></div>

                    <form asp-action="VerifyRegistrationOtp" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="VerifiedName" />
                        <input type="hidden" asp-for="Step" value="2" />

                        <div class="mb-2">
                            <label asp-for="OtpCode" class="form-label"></label>
                            <input asp-for="OtpCode" class="form-control" maxlength="6" autocomplete="one-time-code" />
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">Verify OTP</button>
                    </form>
                }

                @if (step == 3)
                {
                    <form asp-action="CompleteRegister" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="VerifiedName" />
                        <input type="hidden" asp-for="OtpCode" />
                        <input type="hidden" asp-for="Step" value="3" />
                        <input type="hidden" asp-for="IsOtpSent" />
                        <input type="hidden" asp-for="IsOtpVerified" />
                        <input type="hidden" asp-for="IsVerified" />

                        <div class="alert alert-success py-2">OTP verified. Complete your registration details below.</div>

                        <!-- Display Student Details if Student -->
                        @if (Model.UserRole == "Student")
                        {
                            <div class="mb-2">
                                <label class="form-label">Enrollment No</label>
                                <input type="text" class="form-control" value="@Model.StudentEnrollmentNo" readonly />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" value="@Model.VerifiedName" readonly />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Email ID</label>
                                <input type="email" class="form-control" value="@Model.Email" readonly />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Phone Number</label>
                                <input type="text" class="form-control" value="@Model.StudentPhone" readonly />
                            </div>
                        }

                        <!-- Display Teacher Details if Teacher -->
                        @if (Model.UserRole == "Teacher")
                        {
                            <div class="mb-2">
                                <label class="form-label">Teacher ID</label>
                                <input type="text" class="form-control" value="@Model.TeacherTeacherId" readonly />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" value="@Model.VerifiedName" readonly />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Email ID</label>
                                <input type="email" class="form-control" value="@Model.Email" readonly />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Phone Number</label>
                                <input type="text" class="form-control" value="@Model.TeacherPhone" readonly />
                            </div>
                        }

                        <hr class="my-3" />

                        <div class="mb-2">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="password-wrapper">
                                <input asp-for="Password" type="password" class="form-control" id="registerPassword" inputmode="numeric" maxlength="4" pattern="\\d{4}" autocomplete="new-password" />
                                <button type="button" class="password-toggle" onclick="togglePassword('registerPassword')" aria-label="Toggle password visibility">
                                    <svg id="registerPassword-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.066 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <div class="password-wrapper">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" id="registerConfirmPassword" inputmode="numeric" maxlength="4" pattern="\\d{4}" autocomplete="new-password" />
                                <button type="button" class="password-toggle" onclick="togglePassword('registerConfirmPassword')" aria-label="Toggle password visibility">
                                    <svg id="registerConfirmPassword-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.066 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Create Account</button>
                    </form>
                }

                <div class="mt-3 text-center">
                    <a href="/Login" class="link-btn-primary">Back to Login</a>
                </div>
    <script>
        function togglePassword(inputId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(inputId + '-icon');
            var isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            if (isHidden) {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />';
            } else {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.066 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />';
            }
        }
    </script>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
