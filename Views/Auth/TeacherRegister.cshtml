@model SmartELibrary.ViewModels.TeacherFirstTimeRegistrationViewModel
@{
    ViewData["Title"] = "Teacher First-Time Setup";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card auth-card">
            <div class="card-body">
                <h4 class="mb-3">Teacher First-Time Setup</h4>
                <p class="text-muted small">Verify Teacher ID or Phone and set your password.</p>

                <div asp-validation-summary="All" class="text-danger mb-2"></div>

                <form asp-action="VerifyTeacherRegistration" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label asp-for="TeacherIdentifier" class="form-label"></label>
                        <input asp-for="TeacherIdentifier" class="form-control" readonly="@(Model.IsVerified ? "readonly" : null)" />
                    </div>

                    @if (!Model.IsVerified)
                    {
                        <button type="submit" class="btn btn-outline-primary w-100">Verify Teacher Details</button>
                    }
                </form>

                @if (Model.IsVerified)
                {
                    <form asp-action="CompleteTeacherRegistration" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TeacherIdentifier" />
                        <input type="hidden" asp-for="IsVerified" />

                        <div class="mb-2">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" readonly />
                        </div>
                        <div class="mb-2">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" type="password" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Set Password</button>
                    </form>
                }

                <div class="mt-3 text-center">
                    <a href="/Login" class="link-btn-primary">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
