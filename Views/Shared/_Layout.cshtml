<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduVault</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/teacher.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />
</head>
@{
    var role = Context.Session.GetString("Role");
    var name = Context.Session.GetString("Name") ?? "Guest";
}
<body class="@(string.IsNullOrWhiteSpace(role) ? "dark-theme" : "light-theme")">

<header class="saas-nav">
    <div class="d-flex align-items-center mb-1 mt-1">
        <a class="brand-link" asp-controller="Home" asp-action="Index">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" class="me-2" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7L12 12L22 7L12 2Z" fill="#A855F7"/>
                <path d="M2 17L12 22L22 17" stroke="#4F9CF9" stroke-width="2" />
                <path d="M2 12L12 17L22 12" stroke="#4F9CF9" stroke-width="2" />
            </svg>
            EduVault
        </a>
    </div>
    
    <div class="d-flex align-items-center gap-3">
        @if (string.IsNullOrWhiteSpace(role))
        {
            <a href="/Login" class="btn-ghost-nav">Login</a>
            <a href="/Account/Register" class="btn-solid-nav">Register</a>
        }
        else if (role == "Admin")
        {
            <a href="/Auth/ChangePassword" class="text-white text-decoration-none small me-2 hover-glow">Change Password</a>
            <a class="btn btn-sm" style="background-color: rgba(255,255,255,0.1); color: #fff; border-radius: 20px; padding: 8px 20px; border: 1px solid rgba(255,255,255,0.2);" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
            <span class="badge" style="background-color: rgba(255,255,255,0.1); color: #fff; border-radius: 20px; padding: 10px 20px; font-weight: normal; font-size: 0.95rem; border: 1px solid rgba(255,255,255,0.2);">System Admin (Admin)</span>
        }
        else
        {
            <a href="/Auth/ChangePassword" class="text-white text-decoration-none small me-2 hover-glow">Change Password</a>
            <span class="user-chip text-white fw-semibold" style="background-color: rgba(255,255,255,0.1); border-radius: 20px; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.2);">@name (@(role))</span>
        }
    </div>
</header>

<div class="app-shell d-flex w-100">
    @if (!string.IsNullOrWhiteSpace(role))
    {
        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-title mt-3 mb-3 ms-2 fs-5 text-white" style="font-weight: 800;">Menu</div>
            @if (role == "Admin")
            {
                <a asp-controller="Admin" asp-action="Dashboard" class="text-white nav-link py-2 pe-3">Dashboard</a>
                <a asp-controller="Admin" asp-action="Users" class="text-white nav-link py-2 pe-3 mt-1">Users</a>
                <a asp-controller="Admin" asp-action="TeachersOnboarding" class="text-white nav-link py-2 pe-3 mt-1">Teachers Onboarding</a>
                <a asp-controller="Admin" asp-action="StudentsOnboarding" class="text-white nav-link py-2 pe-3 mt-1">Students Onboarding</a>
                <a asp-controller="Admin" asp-action="Semesters" class="text-white nav-link py-2 pe-3 mt-1">Semesters</a>
                <a asp-controller="Admin" asp-action="Subjects" class="text-white nav-link py-2 pe-3 mt-1">Subjects</a>
                <a asp-controller="Admin" asp-action="AssignTeachers" class="text-white nav-link py-2 pe-3 mt-1">Assign Teacher</a>
                <a asp-controller="Admin" asp-action="SemesterStudents" class="text-white nav-link py-2 pe-3 mt-1">Semester Students</a>
                <a asp-controller="Admin" asp-action="Reports" class="text-white nav-link py-2 pe-3 mt-1">Reports</a>
                <a asp-controller="Admin" asp-action="SemesterResults" class="text-white nav-link py-2 pe-3 mt-1">Semester Results</a>
            }
            else if (role == "Teacher")
            {
                <a asp-controller="Teacher" asp-action="Dashboard" class="text-white nav-link py-2 pe-3">Dashboard</a>
                <a asp-controller="Teacher" asp-action="UploadMaterial" class="text-white nav-link py-2 pe-3 mt-1">Upload Chapter</a>
                <a asp-controller="Teacher" asp-action="UploadFile" class="text-white nav-link py-2 pe-3 mt-1">Upload File</a>
                <a asp-controller="Teacher" asp-action="Materials" class="text-white nav-link py-2 pe-3 mt-1">Materials</a>
                <a asp-controller="Teacher" asp-action="CreateQuiz" class="text-white nav-link py-2 pe-3 mt-1">Create Quiz</a>
                <a asp-controller="Teacher" asp-action="Quizzes" class="text-white nav-link py-2 pe-3 mt-1">Quizzes</a>
                <a asp-controller="Teacher" asp-action="Progress" class="text-white nav-link py-2 pe-3 mt-1">Analytics</a>
            }
            else if (role == "Student")
            {
                <a asp-controller="Student" asp-action="Dashboard" class="text-white nav-link py-2 pe-3">Dashboard</a>
                <a asp-controller="Student" asp-action="EnrollSemester" class="text-white nav-link py-2 pe-3 mt-1">Enroll Semester</a>
                <a asp-controller="Student" asp-action="Library" class="text-white nav-link py-2 pe-3 mt-1">Digital Library</a>
                <a asp-controller="Student" asp-action="Quizzes" class="text-white nav-link py-2 pe-3 mt-1">My Quizzes</a>
                <a asp-controller="Student" asp-action="SemesterResults" class="text-white nav-link py-2 pe-3 mt-1">My Results</a>
            }
            <a asp-controller="Auth" asp-action="Logout" class="nav-link sidebar-logout-btn mt-auto mb-2">Logout</a>
        </aside>
    }

    <div class="content-area p-4 @(string.IsNullOrWhiteSpace(role) ? "w-100" : "flex-grow-1")" style="background: transparent;">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: rgba(40, 167, 69, 0.1); border: 1px solid rgba(40, 167, 69, 0.3); color: #28a745;">
                <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.3); color: #dc3545;">
                <i class="bi bi-exclamation-octagon me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @RenderBody()
    </div>
</div>

<!-- Include Footer Partial -->
<partial name="_Footer" />

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleBtn = document.getElementById("sidebarToggle");
        const sidebar = document.getElementById("appSidebar");
        if (toggleBtn && sidebar) {
            toggleBtn.addEventListener("click", function () {
                sidebar.classList.toggle("show");
            });
        }

        // Active state highlight based on current path
        const currentPath = window.location.pathname.toLowerCase();
        const sidebarLinks = document.querySelectorAll('.sidebar a');
        sidebarLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href && href.toLowerCase() === currentPath) {
                link.classList.add('active');
                link.style.background = 'rgba(255, 255, 255, 0.1)';
                link.style.borderRadius = '5px';
            }
        });
    });
</script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
