@model SmartELibrary.ViewModels.UnifiedRegisterViewModel
@{
    ViewData["Title"] = "Register";

    var currentStep = (Model.CurrentStep ?? "lookup").ToLowerInvariant();
    var isLookupStep = currentStep == "lookup";
    var isVerifyStep = currentStep == "verify-otp";
    var isSetPasswordStep = currentStep == "set-password";
}

<div class="row justify-content-center auth-login-shell">
    <div class="col-md-5 col-lg-5">
        <div class="card auth-card auth-login-card">
            <div class="card-body auth-login-body">
                <h4 class="mb-1">Registration</h4>
                <p class="mb-3 auth-login-subtitle">EduVault Registration</p>


                <form asp-action="Register" method="post" class="auth-login-form">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <input type="hidden" asp-for="CurrentStep" />

                    @if (isLookupStep)
                    {
                        <div class="mb-2">
                            <label asp-for="UserIdentifier" class="form-label">User ID</label>
                            <input asp-for="UserIdentifier" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                        </div>
                        <button type="submit" name="actionType" value="request-otp" class="btn btn-primary w-100">Send Verification OTP</button>
                    }

                    @if (isVerifyStep || isSetPasswordStep)
                    {
                        @if (isVerifyStep)
                        {
                            <div class="alert alert-info mb-3">
                                Account Verify: <strong>@Model.FullName</strong>
                            </div>
                        }
                    }

                    @if (isVerifyStep)
                    {
                        @if (!string.IsNullOrWhiteSpace(Model.DebugOtp))
                        {
                            <div class="alert alert-info mb-3">
                                Demo OTP: <strong>@Model.DebugOtp</strong>
                            </div>
                        }
                        <div class="mb-3">
                            <label asp-for="OtpCode" class="form-label">Verification OTP</label>
                            <input asp-for="OtpCode" class="form-control" maxlength="6" />
                        </div>
                        <button type="submit" name="actionType" value="verify-otp" class="btn btn-primary w-100">Verify OTP</button>
                    }

                    @if (isSetPasswordStep)
                    {
                        @if (Model.Role == SmartELibrary.Models.UserRole.Student)
                        {
                            <div class="mb-2">
                                <label class="form-label">Enrollment No</label>
                                <input class="form-control" value="@(Model.EnrollmentNumber ?? string.Empty)" readonly />
                            </div>
                        }

                        @if (Model.Role == SmartELibrary.Models.UserRole.Teacher)
                        {
                            <div class="mb-2">
                                <label class="form-label">Teacher ID</label>
                                <input class="form-control" value="@(Model.TeacherId ?? string.Empty)" readonly />
                            </div>
                        }

                        <div class="mb-2">
                            <label class="form-label">Name</label>
                            <input class="form-control" value="@Model.FullName" readonly />
                        </div>

                        <div class="mb-2">
                            <label class="form-label">Phone</label>
                            <input class="form-control" value="@Model.PhoneNumber" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" value="@Model.Email" readonly />
                        </div>

                        <div class="mb-2">
                            <label asp-for="Password" class="form-label">Set Password</label>
                            <div class="password-wrapper">
                                <input asp-for="Password" class="form-control" id="registerPassword" type="password" />
                                <button type="button" class="password-toggle" onclick="togglePassword('registerPassword')" aria-label="Toggle password visibility">
                                    <svg id="registerPassword-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.066 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                            <div class="password-wrapper">
                                <input asp-for="ConfirmPassword" class="form-control" id="registerConfirmPassword" type="password" />
                                <button type="button" class="password-toggle" onclick="togglePassword('registerConfirmPassword')" aria-label="Toggle password visibility">
                                    <svg id="registerConfirmPassword-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.066 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <button type="submit" name="actionType" value="set-password" class="btn btn-primary w-100">Complete Registration</button>
                    }
                </form>
                <div class="auth-login-footer text-center">
                    <a href="/Login" class="link-btn-primary">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(inputId + '-icon');
            if (!input || !icon) {
                return;
            }
            var isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            if (isHidden) {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />';
            } else {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.066 7.498a10.522 10.522 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />';
            }
        }
    </script>
}