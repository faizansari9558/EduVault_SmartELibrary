@model SmartELibrary.ViewModels.AdminUsersViewModel
@{
    ViewData["Title"] = "Manage Users";
}

<style>
    .created-col {
        white-space: nowrap;
        min-width: 120px;
    }
</style>

<div class="card">
    <div class="card-body table-responsive">
        <form class="row g-2 align-items-end mb-2" method="get" id="usersFilterForm">
            <div class="col-sm-4">
                <label class="form-label">Filter</label>
                <select class="form-select" name="role">
                    <option value="All" selected="@(string.Equals(Model.RoleFilter, "All", StringComparison.OrdinalIgnoreCase))">All</option>
                    <option value="Admin" selected="@(string.Equals(Model.RoleFilter, "Admin", StringComparison.OrdinalIgnoreCase))">Admin</option>
                    <option value="Teacher" selected="@(string.Equals(Model.RoleFilter, "Teacher", StringComparison.OrdinalIgnoreCase))">Teacher</option>
                    <option value="Student" selected="@(string.Equals(Model.RoleFilter, "Student", StringComparison.OrdinalIgnoreCase))">Student</option>
                </select>
            </div>
            <div class="col-sm-6">
                <label class="form-label">Search Users</label>
                <input
                    type="text"
                    class="form-control"
                    id="usersLiveSearch"
                    name="search"
                    value="@Model.SearchTerm"
                    placeholder="Search by name, phone, role, teacher id, enrollment no, semester" />
            </div>
            <div class="col-sm-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
            </div>
        </form>

        <div class="small text-muted mb-3">Live filtering is active while typing in Search Users.</div>

        @{
            var admins = Model.Users.Where(x => string.Equals(x.Role, "Admin", StringComparison.OrdinalIgnoreCase)).ToList();
            var teachers = Model.Users.Where(x => string.Equals(x.Role, "Teacher", StringComparison.OrdinalIgnoreCase)).ToList();
            var students = Model.Users.Where(x => string.Equals(x.Role, "Student", StringComparison.OrdinalIgnoreCase)).ToList();
        }

        @if (admins.Count > 0)
        {
            <div class="d-flex justify-content-between align-items-center mt-2 mb-2">
                <h5 class="mb-0">Admins</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary users-select-all-btn" data-section="admin">Select All</button>
                    <button type="button" class="btn btn-sm btn-outline-danger users-delete-selected-btn" data-section="admin">Delete Selected</button>
                </div>
            </div>
            <table class="table table-striped align-middle users-table admin-table" data-section="admin">
                <thead>
                <tr>
                    <th style="width: 70px;">Select</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Approved</th>
                    <th class="created-col">Created</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var user in admins)
                {
                    var statusClass = user.IsApproved ? "bg-success" : "bg-warning";
                    var canDelete = user.UserId != 1;
                    var searchBlob = string.Join(" ", new[]
                    {
                        user.Name,
                        user.PhoneNumber,
                        user.Role,
                        user.TeacherId ?? string.Empty,
                        user.EnrollmentNumber ?? string.Empty,
                        user.CurrentSemesterName ?? string.Empty
                    }).ToLowerInvariant();
                    <tr data-users-search="@searchBlob">
                        <td>
                            <input
                                type="checkbox"
                                class="form-check-input users-row-select"
                                data-section="admin"
                                value="@user.UserId"
                                @(canDelete ? null : "disabled") />
                        </td>
                        <td>@user.Name</td>
                        <td>@user.PhoneNumber</td>
                        <td><span class="badge @statusClass">@(user.IsApproved ? "Approved" : "Pending")</span></td>
                        <td class="created-col">@user.CreatedAtUtc.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-primary" asp-action="EditUser" asp-route-userId="@user.UserId">Edit</a>

                                @if (!user.IsApproved)
                                {
                                    <form asp-action="ApproveUser" method="post">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <input type="hidden" name="role" value="@Model.RoleFilter" />
                                        <input type="hidden" name="search" value="@Model.SearchTerm" />
                                        <button class="btn btn-sm btn-success" type="submit">Approve</button>
                                    </form>
                                }

                                <form asp-action="DeleteUser" method="post" class="delete-user-form" data-user-name="@user.Name">
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <input type="hidden" name="role" value="@Model.RoleFilter" />
                                    <input type="hidden" name="search" value="@Model.SearchTerm" />
                                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        @if (teachers.Count > 0)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 mb-2">
                <h5 class="mb-0">Teachers</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary users-select-all-btn" data-section="teacher">Select All</button>
                    <button type="button" class="btn btn-sm btn-outline-danger users-delete-selected-btn" data-section="teacher">Delete Selected</button>
                </div>
            </div>
            <table class="table table-striped align-middle users-table admin-table" data-section="teacher">
                <thead>
                <tr>
                    <th style="width: 70px;">Select</th>
                    <th>Teacher ID</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Approved Teacher</th>
                    <th class="created-col">Created</th>
                    <th>Assigned Subjects</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var user in teachers)
                {
                    var statusClass = user.IsApproved ? "bg-success" : "bg-warning";
                    var searchBlob = string.Join(" ", new[]
                    {
                        user.Name,
                        user.PhoneNumber,
                        user.Role,
                        user.TeacherId ?? string.Empty,
                        user.EnrollmentNumber ?? string.Empty,
                        user.CurrentSemesterName ?? string.Empty
                    }).ToLowerInvariant();
                    <tr data-users-search="@searchBlob">
                        <td>
                            <input type="checkbox" class="form-check-input users-row-select" data-section="teacher" value="@user.UserId" />
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(user.TeacherId) ? "-" : user.TeacherId)</td>
                        <td>@user.Name</td>
                        <td>@user.PhoneNumber</td>
                        <td><span class="badge @statusClass">@(user.IsApproved ? "Approved" : "Pending")</span></td>
                        <td class="created-col">@user.CreatedAtUtc.ToString("dd/MM/yyyy")</td>
                        <td>@(user.AssignedSubjectCount.HasValue ? user.AssignedSubjectCount.Value.ToString() : "-")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a class="btn btn-sm btn-primary" asp-action="EditUser" asp-route-userId="@user.UserId">Edit</a>

                                @if (!user.IsApproved)
                                {
                                    <form asp-action="ApproveUser" method="post">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <input type="hidden" name="role" value="@Model.RoleFilter" />
                                        <input type="hidden" name="search" value="@Model.SearchTerm" />
                                        <button class="btn btn-sm btn-success" type="submit">Approve</button>
                                    </form>
                                }

                                <form asp-action="DeleteUser" method="post" class="delete-user-form" data-user-name="@user.Name">
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <input type="hidden" name="role" value="@Model.RoleFilter" />
                                    <input type="hidden" name="search" value="@Model.SearchTerm" />
                                    <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        @if (students.Count > 0)
        {
            <div class="d-flex justify-content-between align-items-center mt-4 mb-2">
                <h5 class="mb-0">Students</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary users-select-all-btn" data-section="student">Select All</button>
                    <button type="button" class="btn btn-sm btn-outline-danger users-delete-selected-btn" data-section="student">Delete Selected</button>
                </div>
            </div>
            <table class="table table-striped align-middle users-table admin-table" data-section="student">
                <thead>
                <tr>
                    <th style="width: 70px;">Select</th>
                    <th>Enrollment No</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Approved Student</th>
                    <th class="created-col">Created</th>
                    <th>Current Semester</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var user in students)
                {
                    var statusClass = user.IsApproved ? "bg-success" : "bg-warning";
                    var searchBlob = string.Join(" ", new[]
                    {
                        user.Name,
                        user.PhoneNumber,
                        user.Role,
                        user.TeacherId ?? string.Empty,
                        user.EnrollmentNumber ?? string.Empty,
                        user.CurrentSemesterName ?? string.Empty
                    }).ToLowerInvariant();
                    <tr data-users-search="@searchBlob">
                        <td>
                            <input type="checkbox" class="form-check-input users-row-select" data-section="student" value="@user.UserId" />
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(user.EnrollmentNumber) ? "-" : user.EnrollmentNumber)</td>
                        <td>@user.Name</td>
                        <td>@user.PhoneNumber</td>
                        <td><span class="badge @statusClass">@(user.IsApproved ? "Approved" : "Pending")</span></td>
                        <td class="created-col">@user.CreatedAtUtc.ToString("dd/MM/yyyy")</td>
                        <td>@(string.IsNullOrWhiteSpace(user.CurrentSemesterName) ? "-" : user.CurrentSemesterName)</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a class="btn btn-sm btn-primary" asp-action="EditUser" asp-route-userId="@user.UserId">Edit</a>

                                    @if (!user.IsApproved)
                                    {
                                        <form asp-action="ApproveUser" method="post">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <input type="hidden" name="role" value="@Model.RoleFilter" />
                                            <input type="hidden" name="search" value="@Model.SearchTerm" />
                                            <button class="btn btn-sm btn-success" type="submit">Approve</button>
                                        </form>
                                    }

                                    <form asp-action="DeleteUser" method="post" class="delete-user-form" data-user-name="@user.Name">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <input type="hidden" name="role" value="@Model.RoleFilter" />
                                        <input type="hidden" name="search" value="@Model.SearchTerm" />
                                        <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                    </tr>
                }
                </tbody>
            </table>
        }

        @if (admins.Count == 0 && teachers.Count == 0 && students.Count == 0)
        {
            <div class="text-muted">No users found for the selected filter.</div>
        }
    </div>
</div>

<form id="bulkDeleteUsersForm" asp-action="DeleteUsersBulk" method="post" class="d-none">
    <input type="hidden" name="role" value="@Model.RoleFilter" />
    <input type="hidden" name="search" value="@Model.SearchTerm" />
    <div id="bulkDeleteUsersIds"></div>
</form>

<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm User Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="deleteUserModalBody">
                Are you sure you want to delete this user?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteUserBtn">Yes, Delete User</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bulkDeleteUsersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Bulk User Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="bulkDeleteUsersModalBody">
                Delete selected users?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmBulkDeleteUsersBtn">Yes, Delete Selected</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const forms = document.querySelectorAll(".delete-user-form");
        const modalElement = document.getElementById("deleteUserModal");
        const modalBody = document.getElementById("deleteUserModalBody");
        const confirmBtn = document.getElementById("confirmDeleteUserBtn");
        const searchInput = document.getElementById("usersLiveSearch");
        const sectionSelectAllButtons = document.querySelectorAll(".users-select-all-btn");
        const sectionDeleteButtons = document.querySelectorAll(".users-delete-selected-btn");
        const bulkDeleteModalElement = document.getElementById("bulkDeleteUsersModal");
        const bulkDeleteModalBody = document.getElementById("bulkDeleteUsersModalBody");
        const confirmBulkDeleteBtn = document.getElementById("confirmBulkDeleteUsersBtn");
        const bulkDeleteForm = document.getElementById("bulkDeleteUsersForm");
        const bulkDeleteIdsContainer = document.getElementById("bulkDeleteUsersIds");

        if (!modalElement || !confirmBtn) {
            return;
        }

        const modal = new bootstrap.Modal(modalElement);
        const bulkDeleteModal = bulkDeleteModalElement ? new bootstrap.Modal(bulkDeleteModalElement) : null;
        let pendingForm = null;
        let pendingBulkDeleteSection = null;

        forms.forEach(form => {
            form.addEventListener("submit", function (event) {
                event.preventDefault();
                pendingForm = this;

                const userName = this.getAttribute("data-user-name") || "this user";
                modalBody.textContent = "Delete " + userName + "?";
                modal.show();
            });
        });

        confirmBtn.addEventListener("click", function () {
            if (pendingForm) {
                const formToSubmit = pendingForm;
                pendingForm = null;
                modal.hide();
                formToSubmit.submit();
            }
        });

        const normalize = value => (value || "").toLowerCase().trim();

        const applyLiveSearch = () => {
            const term = normalize(searchInput ? searchInput.value : "");
            document.querySelectorAll(".users-table tbody tr").forEach(row => {
                const haystack = normalize(row.getAttribute("data-users-search"));
                row.style.display = !term || haystack.includes(term) ? "" : "none";
            });
        };

        if (searchInput) {
            searchInput.addEventListener("input", applyLiveSearch);
            applyLiveSearch();
        }

        sectionSelectAllButtons.forEach(button => {
            button.addEventListener("click", function () {
                const section = this.getAttribute("data-section");
                const checkboxes = Array.from(document.querySelectorAll('.users-row-select[data-section="' + section + '"]'));
                const visibleEnabledCheckboxes = checkboxes.filter(cb => !cb.disabled && cb.closest("tr") && cb.closest("tr").style.display !== "none");
                const allChecked = visibleEnabledCheckboxes.length > 0 && visibleEnabledCheckboxes.every(cb => cb.checked);
                visibleEnabledCheckboxes.forEach(cb => {
                    cb.checked = !allChecked;
                });
            });
        });

        sectionDeleteButtons.forEach(button => {
            button.addEventListener("click", function () {
                const section = this.getAttribute("data-section");
                const selected = Array.from(document.querySelectorAll('.users-row-select[data-section="' + section + '"]:checked'));
                if (!selected.length || !bulkDeleteModal || !bulkDeleteModalBody) {
                    return;
                }

                pendingBulkDeleteSection = section;
                bulkDeleteModalBody.textContent = "Delete " + selected.length + " selected user(s) from " + section + " section?";
                bulkDeleteModal.show();
            });
        });

        if (confirmBulkDeleteBtn) {
            confirmBulkDeleteBtn.addEventListener("click", function () {
                if (!pendingBulkDeleteSection || !bulkDeleteForm || !bulkDeleteIdsContainer) {
                    return;
                }

                const selected = Array.from(document.querySelectorAll('.users-row-select[data-section="' + pendingBulkDeleteSection + '"]:checked'));
                if (!selected.length) {
                    pendingBulkDeleteSection = null;
                    if (bulkDeleteModal) {
                        bulkDeleteModal.hide();
                    }
                    return;
                }

                bulkDeleteIdsContainer.innerHTML = "";
                selected.forEach(cb => {
                    const input = document.createElement("input");
                    input.type = "hidden";
                    input.name = "userIds";
                    input.value = cb.value;
                    bulkDeleteIdsContainer.appendChild(input);
                });

                pendingBulkDeleteSection = null;
                if (bulkDeleteModal) {
                    bulkDeleteModal.hide();
                }
                bulkDeleteForm.submit();
            });
        }
    });
</script>
