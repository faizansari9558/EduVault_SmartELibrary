@model SmartELibrary.ViewModels.AdminStudentOnboardingPageViewModel
@{
    ViewData["Title"] = "Students Onboarding";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Students Onboarding</h4>
    <a asp-action="DownloadStudentOnboardingTemplate" class="btn btn-outline-secondary btn-sm">Download Sample Excel</a>
</div>

<!-- Upper Section: Add Student Manually (Left) & Bulk Upload (Right) -->
<div class="row gy-3 gx-3 mb-3">
    <!-- Left Column: Add Student Manually -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-3">Add Student Manually</h6>
                <form asp-action="AddStudentManually" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <div class="col-12">
                        <label class="form-label">Enrollment No</label>
                        <input name="enrollmentNo" type="text" class="form-control" placeholder="e.g., ENR2026001" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Name</label>
                        <input name="name" type="text" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Email</label>
                        <input name="email" type="email" class="form-control" placeholder="student@example.com" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Phone</label>
                        <input name="phone" type="text" class="form-control" placeholder="Phone number" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Date of Birth</label>
                        <input name="dateOfBirth" type="date" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Semester</label>
                        <select name="semesterId" class="form-select" required>
                            <option value="">Select semester</option>
                            @{
                                var semesters = ViewBag.Semesters as List<SmartELibrary.Models.Semester> ?? new();
                                foreach (var semester in semesters)
                                {
                                    <option value="@semester.Id">@semester.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary w-100">Add Student</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Bulk Upload Students -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-3">Bulk Upload Students (.xlsx)</h6>
                <form asp-action="UploadStudentOnboardingExcel" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-12">
                        <label asp-for="Upload.ExcelFile" class="form-label"></label>
                        <input asp-for="Upload.ExcelFile" type="file" class="form-control" accept=".xlsx" />
                        <div class="form-text">Columns: EnrollmentNo, Name, Email, Phone, DateOfBirth, Semester</div>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary w-100">Upload Students</button>
                    </div>
                </form>

                @if (Model.LastImportResult is not null)
                {
                    <hr />
                    <div>
                        <div>Total Rows: <strong>@Model.LastImportResult.TotalRows</strong></div>
                        <div>Imported: <strong>@Model.LastImportResult.ImportedRows</strong></div>
                    </div>

                    @if (Model.LastImportResult.Errors.Any())
                    {
                        <div class="alert alert-warning mb-0">
                            <strong>Validation Errors:</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var error in Model.LastImportResult.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Lower Section: Students Table -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Students</span>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-striped mb-0 admin-table">
                    <thead>
                        <tr>
                            <th>Enrollment No</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>DOB</th>
                            <th>Semester</th>
                            <th>Registered</th>
                            <th>Imported At</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Rows.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No students found.</td></tr>
                    }
                    else
                    {
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@row.EnrollmentNo</td>
                                <td>@row.Name</td>
                                <td>@row.Email</td>
                                <td>@row.Phone</td>
                                <td>@row.DateOfBirth.ToString("yyyy-MM-dd")</td>
                                <td>@row.SemesterName</td>
                                <td>
                                    <span class="badge @(row.IsRegistered ? "bg-success" : "bg-warning text-dark")">
                                        @(row.IsRegistered ? "Yes" : "No")
                                    </span>
                                </td>
                                <td>@row.ImportedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
