@model SmartELibrary.ViewModels.TeacherManagementPageViewModel
@{
    ViewData["Title"] = "Teachers Onboarding";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Teachers Onboarding</h4>
    <a asp-action="DownloadTeacherTemplate" class="btn btn-outline-secondary btn-sm">Download Teacher Excel Template</a>
</div>

<!-- Upper Section: Add Teacher Manually (Left) & Bulk Upload (Right) -->
<div class="row gy-3 gx-3 mb-3">
    <!-- Left Column: Add Teacher Manually -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-3">Add Teacher Manually</h6>
                <form asp-action="AddTeacher" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <div class="col-12">
                        <label asp-for="Manual.TeacherId" class="form-label"></label>
                        <input asp-for="Manual.TeacherId" class="form-control" placeholder="Optional. Auto-generated if empty" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Manual.Name" class="form-label"></label>
                        <input asp-for="Manual.Name" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Manual.Phone" class="form-label"></label>
                        <input asp-for="Manual.Phone" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Manual.Email" class="form-label"></label>
                        <input asp-for="Manual.Email" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary w-100">Add Teacher</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Bulk Upload Teachers -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-3">Bulk Upload Teachers (.xlsx)</h6>
                <form asp-action="UploadTeachersExcel" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-12">
                        <label asp-for="Upload.ExcelFile" class="form-label"></label>
                        <input asp-for="Upload.ExcelFile" type="file" class="form-control" accept=".xlsx" />
                        <div class="form-text">Columns: TeacherId, Name, Phone, Email</div>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary w-100">Upload Teachers</button>
                    </div>
                </form>

                @if (Model.LastImportResult is not null)
                {
                    <hr />
                    <div>
                        <div>Total Rows: <strong>@Model.LastImportResult.TotalRows</strong></div>
                        <div>Imported: <strong>@Model.LastImportResult.ImportedRows</strong></div>
                    </div>

                    @if (Model.LastImportResult.Errors.Any())
                    {
                        <div class="alert alert-warning mb-0">
                            <strong>Validation Errors:</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var error in Model.LastImportResult.Errors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Lower Section: Teacher Records Table -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped mb-0 admin-table">
                    <thead>
                        <tr>
                            <th>Teacher ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th>First Login</th>
                            <th style="width: 210px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Teachers.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No teacher records found.</td></tr>
                    }
                    else
                    {
                        @foreach (var teacher in Model.Teachers)
                        {
                            <tr>
                                <td>@teacher.TeacherId</td>
                                <td>@teacher.Name</td>
                                <td>@teacher.Email</td>
                                <td>@teacher.Phone</td>
                                <td><span class="badge @(teacher.IsActive ? "bg-success" : "bg-danger")">@(teacher.IsActive ? "Active" : "Inactive")</span></td>
                                <td><span class="badge @(teacher.IsFirstLogin ? "bg-warning text-dark" : "bg-secondary")">@(teacher.IsFirstLogin ? "Pending" : "Completed")</span></td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="EditTeacher" asp-route-userId="@teacher.UserId" class="btn btn-sm btn-primary">Edit</a>
                                        @if (teacher.IsActive)
                                        {
                                            <form asp-action="DeactivateTeacher" asp-route-userId="@teacher.UserId" method="post" class="deactivate-teacher-form" data-teacher-name="@teacher.Name">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger">Deactivate</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deactivateTeacherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Teacher Deactivation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="deactivateTeacherModalBody">
                Are you sure you want to deactivate this teacher?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeactivateTeacherBtn">Yes, Deactivate</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const forms = document.querySelectorAll(".deactivate-teacher-form");
        const modalElement = document.getElementById("deactivateTeacherModal");
        const modalBody = document.getElementById("deactivateTeacherModalBody");
        const confirmBtn = document.getElementById("confirmDeactivateTeacherBtn");

        if (!modalElement || !confirmBtn) {
            return;
        }

        const modal = new bootstrap.Modal(modalElement);
        let pendingForm = null;

        forms.forEach(form => {
            form.addEventListener("submit", function (event) {
                event.preventDefault();
                pendingForm = this;

                const teacherName = this.getAttribute("data-teacher-name") || "this teacher";
                modalBody.textContent = "Deactivate " + teacherName + "?";
                modal.show();
            });
        });

        confirmBtn.addEventListener("click", function () {
            if (pendingForm) {
                const formToSubmit = pendingForm;
                pendingForm = null;
                modal.hide();
                formToSubmit.submit();
            }
        });
    });
</script>
