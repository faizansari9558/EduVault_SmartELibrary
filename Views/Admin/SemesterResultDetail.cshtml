@model SmartELibrary.ViewModels.SemesterResultDetailViewModel
@{
    ViewData["Title"] = $"Results — {Model.SemesterName}";
    var hasApprovedStudents = Model.Students.Any();
}

<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <h2 class="mb-0">@Model.SemesterName — Results</h2>
    @if (Model.IsPublished)
    {
        <span class="badge bg-success fs-6">Published</span>
    }
    else
    {
        <span class="badge bg-secondary fs-6">Not Published</span>
    }
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a asp-action="SemesterResults" class="btn btn-outline-secondary btn-sm">← Back to Semesters</a>

    @if (Model.IsPublished)
    {
        <form asp-action="UnpublishSemesterResult" method="post" class="semester-result-publish-form d-inline" data-action-label="Unpublish Results" data-action-message="Unpublish results? Students will no longer see their results.">
            <input type="hidden" name="semesterId" value="@Model.SemesterId" />
            <button type="submit" class="btn btn-warning btn-sm">
                Unpublish Results
            </button>
        </form>
    }
    else
    {
        @if (hasApprovedStudents)
        {
            <form asp-action="PublishSemesterResult" method="post" class="semester-result-publish-form d-inline" data-action-label="Publish Results" data-action-message="Publish results? All enrolled students will be able to see their results.">
                <input type="hidden" name="semesterId" value="@Model.SemesterId" />
                <button type="submit" class="btn btn-success btn-sm">
                    Publish Results
                </button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-success btn-sm" disabled title="No approved students are available for this semester.">
                Publish Results
            </button>
        }
    }
</div>

<div class="modal fade" id="publishActionConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="publishActionConfirmTitle">Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="publishActionConfirmBody">
                Are you sure?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmPublishActionBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@if (Model.PublishedAtUtc.HasValue)
{
    <p class="text-muted small">Published on @Model.PublishedAtUtc.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</p>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const forms = document.querySelectorAll(".semester-result-publish-form");
        const modalElement = document.getElementById("publishActionConfirmModal");
        const modalTitle = document.getElementById("publishActionConfirmTitle");
        const modalBody = document.getElementById("publishActionConfirmBody");
        const confirmBtn = document.getElementById("confirmPublishActionBtn");

        if (!forms.length || !modalElement || !confirmBtn || !modalTitle || !modalBody) {
            return;
        }

        const modal = new bootstrap.Modal(modalElement);
        let pendingForm = null;

        forms.forEach(form => {
            form.addEventListener("submit", function (event) {
                event.preventDefault();
                pendingForm = this;

                const actionLabel = this.getAttribute("data-action-label") || "Confirm";
                const actionMessage = this.getAttribute("data-action-message") || "Are you sure?";

                modalTitle.textContent = actionLabel;
                modalBody.textContent = actionMessage;
                confirmBtn.textContent = actionLabel;
                confirmBtn.className = actionLabel.toLowerCase().includes("unpublish")
                    ? "btn btn-warning"
                    : "btn btn-success";

                modal.show();
            });
        });

        confirmBtn.addEventListener("click", function () {
            if (!pendingForm) {
                return;
            }

            const formToSubmit = pendingForm;
            pendingForm = null;
            modal.hide();
            formToSubmit.submit();
        });
    });
</script>

@if (!Model.Students.Any())
{
    <div class="alert alert-info">No approved students enrolled in this semester.</div>
}
else
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Student Results (@Model.Students.Count students)</span>
            <small class="text-muted">Sorted by result (highest first)</small>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0 admin-table">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Enrollment No.</th>
                        <th>Student Name</th>
                        <th class="text-center">Final Result</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Detail</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var s in Model.Students)
                    {
                        <tr>
                            <td>@rank</td>
                            <td>@s.EnrollmentNumber</td>
                            <td>@s.StudentName</td>
                            <td class="text-center">
                                <div class="d-flex align-items-center gap-2 justify-content-center">
                                    <div class="progress" style="width:80px;height:10px;">
                                        <div class="progress-bar @SmartELibrary.ViewModels.SemesterResultHelper.GetProgressBarClass(s.FinalResult)"
                                             style="width:@s.FinalResult%"></div>
                                    </div>
                                    <span>@s.FinalResult%</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="@s.StatusClass fw-semibold">@s.Status</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="AdminStudentResult"
                                   asp-route-studentId="@s.StudentId"
                                   asp-route-semesterId="@Model.SemesterId"
                                   class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}
